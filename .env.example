# Kalshi API credentials
# Generate a key pair and register the public key at https://kalshi.com/account/api
# Then set the key ID and path to your private key file here.
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_API_PRIVATE_KEY_PATH=/run/secrets/kalshi_private_key.pem

# Use demo API (true) or production (false)
KALSHI_DEMO=true

# --- Market selection ---
# Use KALSHI_MARKETS for an explicit list, or KALSHI_MARKET_PATTERN for a regex.
# KALSHI_MARKETS takes precedence if both are set.

# Daily temperature markets — high/low across major US cities
KALSHI_MARKETS=KXHIGHTNYC,KXLOWTNYC,KXHIGHTBOS,KXLOWTBOS,KXHIGHAUS,KXHIGHTDAL,KXLOWTDAL,KXHIGHTHOU,KXHIGHTATL,KXLOWTATL,KXHIGHTPHIL,KXHIGHTSFO,KXLOWTSFO,KXHIGHTSEA,KXLOWTSEA,KXLOWTMIA

# Hourly financial markets — equities, forex, commodities
# KALSHI_MARKETS=KXINXI,KXINXU,NASDAQ100I,KXEURUSDH,KXGBPUSDH,KXUSDJPYH,KXWTIH

# Pattern-based alternative (uncomment and adjust instead of KALSHI_MARKETS)
# KALSHI_MARKET_PATTERN=^KXHIGHT|^KXLOWT
# KALSHI_MARKET_PATTERN=^KXINX|^KXEURUSD|^KXGBPUSD|^KXUSDJPY|^KXWTI

# Trading parameters
TRADING_DRY_RUN=true
TRADING_AMOUNT_PER_TRADE=100.0
TRADING_MAX_POSITIONS=5
TRADING_LIMIT_PADDING_CENTS=1
TRADING_TICK_MINUTE=50

# Which contract sides to trade: yes, no, or yes,no (default: both)
TRADING_SIDES=yes,no

# Starting virtual balance for paper trading
PAPER_BALANCE=10000

# Instance label — prefixes log lines and scopes output to output/<name>/run_*/
# BOT_NAME=paper
